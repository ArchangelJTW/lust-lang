{
  "grammars": [
    {
      "name": "lust",
      "camelcase": "Lust",
      "scope": "source.lust",
      "path": ".",
      "file-types": [
        "lust"
      ],
      "injection-regex": "lust"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Lust programming language",
    "authors": [
      {
        "name": "Lust Language Contributors"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-lust"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
